# ============ MySQL ============
MYSQL_ROOT_PASSWORD=your_mysql_password
MYSQL_DATABASE=qitekcomputer
MYSQL_PORT=3307

# ============ Backend ============
SECRET_KEY=change-this-to-a-random-secret-key
BACKEND_PORT=8000

# ============ Frontend ============
# Leave empty to use same-origin (works with nginx reverse proxy)
# Only set if running frontend without nginx
NEXT_PUBLIC_API_URL=

# Port for the app (nginx reverse proxy)
APP_PORT=80
