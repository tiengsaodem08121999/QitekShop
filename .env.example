# ============ MySQL ============
MYSQL_ROOT_PASSWORD=your_mysql_password
MYSQL_DATABASE=qitekshop
MYSQL_PORT=3306

# ============ Backend ============
SECRET_KEY=change-this-to-a-random-secret-key
BACKEND_PORT=8000

# ============ Frontend ============
# URL that the BROWSER uses to call the backend API
# Production: change to http://your-server-ip:8000 so other devices can access
# Example: NEXT_PUBLIC_API_URL=http://192.168.1.100:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000
