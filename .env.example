# ============ MySQL ============
MYSQL_ROOT_PASSWORD=your_mysql_password
MYSQL_DATABASE=qitekshop
MYSQL_PORT=3306

# ============ Backend ============
SECRET_KEY=change-this-to-a-random-secret-key
